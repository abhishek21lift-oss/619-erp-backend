# 619 Fitness ERP — backend env template
# Copy to .env and fill in real values. NEVER commit .env (it's in .gitignore).

# ── Server ─────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production

# ── Database ───────────────────────────────────────────────────────
# Supabase pooler URI from Supabase → Settings → Database → Connection string → URI
# The pool uses ssl: { rejectUnauthorized: false } to accept Supabase's
# SNI cert. For higher assurance set DATABASE_SSL_CA to the Supabase root
# CA bundle and the pool will switch to verify-full.
DATABASE_URL=postgresql://postgres.<your-project-ref>:<your-db-password>@aws-1-ap-south-1.pooler.supabase.com:6543/postgres
# DATABASE_SSL_CA=/etc/secrets/supabase-ca.pem  ← optional: full cert chain verification
# In production without DATABASE_SSL_CA the pool uses the system CA store (trusts
# Render / Supabase signed certs). rejectUnauthorized:false is only used in dev.
# DATABASE_POOL_SIZE=10

# ── Auth ───────────────────────────────────────────────────────────
# Generate with:  node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Must be at least 32 chars or the server refuses to boot.
JWT_SECRET=<generate: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))">
# Short-lived access token (15m recommended). Paired with a 7-day refresh token.
JWT_EXPIRES_IN=15m

# ── CORS / Frontend origin ─────────────────────────────────────────
FRONTEND_URL=https://619-erp-frontend.vercel.app
# Comma-separated list of allowed origins (overrides FRONTEND_URL)
# CORS_ORIGIN=https://your-app.vercel.app,https://staging.your-app.vercel.app

# ── Email (SMTP / forgot-password) ─────────────────────────────────
# When unset, reset tokens are logged to stdout instead of emailed.
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=SG.your_sendgrid_api_key
# SMTP_FROM=noreply@619fitness.com

# ── Branch (multi-branch deployments) ──────────────────────────────
# Set to the branch ID for this deployment. Defaults to 'br-main'.
# BRANCH_ID=br-main

# ── Kiosk token HMAC (H-05) ────────────────────────────────────────
# Required. Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
KIOSK_HMAC_SECRET=<generate-32-plus-char-random-secret>

# ── Face Encryption (GDPR Art. 9 compliance) ───────────────────────
# Required in production — biometric data is stored as plaintext without this.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
FACE_ENCRYPTION_KEY=<64-hex-chars>

# ── Google OAuth (Sign-In + Calendar) ──────────────────────
# Get from Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
# Authorised JavaScript origins: https://your-frontend.vercel.app
# Authorised redirect URIs: https://your-api.onrender.com/api/calendar/callback
GOOGLE_CLIENT_ID=<your-google-oauth-client-id>.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=<your-google-oauth-client-secret>
# Full URL of this backend's /api/calendar/callback endpoint (must match Google Console)
GOOGLE_CALENDAR_REDIRECT_URI=https://your-api.onrender.com/api/calendar/callback

# ── AI — OpenRouter Multi-Model Gateway ────────────────────────────
# Get your API key at https://openrouter.ai
# Without OPENROUTER_API_KEY, /api/ai/* routes return 501 (not configured).
OPENROUTER_API_KEY=sk-or-v1-c15e9fc9be6868c80845790eb87c1d531df-be89fe9393563cf80509f6aca009d

# Model IDs served via OpenRouter — change without redeploying.
# Primary:   fitness coaching, workout & diet generation, progress analysis
AI_PRIMARY_MODEL=openai/gpt-oss-120b:free
# Secondary: code generation, SQL, technical analysis, debugging
AI_SECONDARY_MODEL=poolside/laguna-m.1:free
# Fallback:  automatic failover, reports, summaries, business insights
AI_FALLBACK_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free

# ── Razorpay (H-06) ────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_<your-key-id>
RAZORPAY_KEY_SECRET=<your-key-secret>
# Webhook secret from Razorpay Dashboard → Webhooks → Secret
RAZORPAY_WEBHOOK_SECRET=<your-webhook-secret>

# ── Admin bootstrap (src/db/seed.js — run once against a fresh DB) ──
# node src/db/seed.js reads these to create the single initial admin
# account. Not read at server boot; only needed when seeding.
ADMIN_EMAIL=<you@example.com>
ADMIN_PASSWORD=<strong-password>
ADMIN_NAME=Admin

# ── WebAuthn / Passkeys (auth-webauthn.js, webauthn.js) ─────────────
# RP_ID must be the bare domain (no scheme/port) the frontend is served
# from; WEBAUTHN_ORIGIN is the full origin(s), comma-separated if you
# serve from more than one (e.g. web + Capacitor). Also referenced by
# render.yaml for the vendor's own deployment — override per client.
RP_ID=your-domain.com
RP_NAME=619 Fitness
WEBAUTHN_ORIGIN=https://your-domain.com

# ── Sentry (error monitoring) ────────────────────────────────────────
# Optional — Sentry is a no-op until SENTRY_DSN is set.
# SENTRY_DSN=https://<key>@<org>.ingest.sentry.io/<project>
# SENTRY_TRACES_SAMPLE_RATE=0.1

# ── Logging ───────────────────────────────────────────────────────────
# pino log level. Defaults to 'info' in production, 'debug' otherwise.
# LOG_LEVEL=info

# ── Email (Resend — preferred over SMTP when set) ────────────────────
# EMAIL_FROM=no-reply@your-domain.com
# RESEND_API_KEY=<your-resend-api-key>

# ── WhatsApp / SMS (Twilio) ───────────────────────────────────────────
# TWILIO_ACCOUNT_SID=<your-twilio-account-sid>
# TWILIO_AUTH_TOKEN=<your-twilio-auth-token>
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# TWILIO_SMS_FROM=+1XXXXXXXXXX

# ── Push notifications (Firebase Cloud Messaging) ─────────────────────
# FCM_SERVER_KEY=<your-fcm-server-key>

# ── Cloudflare R2 (large file storage) ────────────────────────────────
# Optional — without these, uploaded avatars/documents and generated PDFs
# fall back to local disk (fine for dev, but Render's filesystem is
# ephemeral and wipes on every deploy, so set these in production).
# Generate an API token: Cloudflare dashboard → R2 → Manage API Tokens.
# R2_ACCOUNT_ID=<your-cloudflare-account-id>
# R2_ACCESS_KEY_ID=<your-r2-access-key-id>
# R2_SECRET_ACCESS_KEY=<your-r2-secret-access-key>
# R2_BUCKET=client-files
